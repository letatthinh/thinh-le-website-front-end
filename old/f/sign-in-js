'use client'
import BackgroundImageButton from '@/components/buttons/background-image'
import SectionContainer from '@/components/layouts/container/section'
import SignInForm from '@/components/pages/sign-in/child-components/sign-in-form'
import signInConstant from '@/components/pages/sign-in/constant'
import Heading1 from '@/components/texts/h1'
import useReduxTheme from '@/hooks/theme/use-global-theme'
import SignInPagePropertyType from '@/types/properties/pages/sign-in'
import classNameUtility from '@/utilities/class-name'
import Script from 'next/script'
import React, { useState } from 'react'
import TokenClient = google.accounts.oauth2.TokenClient

export default function SignInPage({
  googleIdentityService: {
    apiKey,
    clientId
  }
} : SignInPagePropertyType) {
  const { reduxTheme } = useReduxTheme()
  const [ tokenClient, setTokenClient ] = useState<TokenClient>()

  // Discovery doc URL for APIs used by the quickstart
  const DISCOVERY_DOC = 'https://www.googleapis.com/discovery/v1/apis/drive/v3/rest'

  // Authorization scopes required by the API; multiple scopes can be
  // included, separated by spaces.
  const SCOPES = 'https://www.googleapis.com/auth/drive.metadata.readonly'

  const onSignInWithGoogleButtonClick = (
    _event: React.MouseEvent<HTMLButtonElement>
  ) => {
    _event.preventDefault()
    if (tokenClient) {
      tokenClient.requestAccessToken({prompt: 'consent'})
    }
  }

  const initializeGoogleApiClient = async () => {
    await gapi.client.init({
      apiKey: apiKey,
      // Your API key will be automatically added
      // to the Discovery Document URLs.
      discoveryDocs: [DISCOVERY_DOC]
    })
  }

  const onGoogleApiLoad = () => {
    // For TypeScript, install @types/gapi
    gapi.load('client', initializeGoogleApiClient)
  }

  const onGoogleSignInClientLoad = () => {
    setTokenClient(
      google.accounts.oauth2.initTokenClient({
        client_id: clientId,
        scope: SCOPES,
        callback: async (_tokenResponse) => {
          if (_tokenResponse.error !== undefined) {
            throw (_tokenResponse)
          }

          console.log('Your fking callback', _tokenResponse)
        }
      })
    )
  }

  return <>
    <SectionContainer>
      <Heading1>LOGIN</Heading1>
      <section
        className={classNameUtility.mergeClassNames([
          reduxTheme.borderColor,
          'sm:max-w-sm border-2 p-6 mx-auto'
        ])}>
        <section>
          <SignInForm />
        </section>
        <article>
          <p className='mb-1.5'>Or login via:</p>
          <section className='flex gap-x-3 justify-center'>
            <BackgroundImageButton
              label={signInConstant.googleSignInButton.label}
              className={signInConstant.googleSignInButton.className}
              onClick={onSignInWithGoogleButtonClick}
            />
          </section>
        </article>
      </section>
    </SectionContainer>
    <Script
      async
      src={'https://apis.google.com/js/api.js'}
      onLoad={onGoogleApiLoad}
    />
    <Script
      async
      src={'https://accounts.google.com/gsi/client'}
      onLoad={onGoogleSignInClientLoad}
    />
  </>
}
